# Bug Whisperer Backend — Environment Config (Example)
# Copy this to .env and fill in your values

# LLM Provider (OpenAI-compatible endpoint)
LLM_PROVIDER=openai
LLM_MODEL=openai/deepseek-chat
LLM_API_KEY=your_api_key_here
LLM_ENDPOINT=https://api.deepseek.com/v1
LLM_TEMPERATURE=0.0

# Skip Cognee's LLM connection test (needed for custom endpoints)
COGNEE_SKIP_CONNECTION_TEST=true

# Embeddings Provider - Fastembed (local, free, offline)
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Cognee Storage (local, self-hosted)
DATA_PATH=./data/cognee
COGNEE_SYSTEM_DB_PATH=./data/cognee
GRAPH_DATABASE=networkx
VECTOR_DATABASE=lancedb

# Logging
LOG_LEVEL=ERROR
COGNEE_LOG_FILE=false

# Server
HOST=0.0.0.0
PORT=8000
