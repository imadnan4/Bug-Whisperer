# Set these in Railway dashboard: railway variables set KEY=VALUE
# Or via CLI: railway variables set LLM_API_KEY=sk-...

LLM_PROVIDER=openai
LLM_MODEL=openai/deepseek-chat
LLM_API_KEY=<your-deepseek-api-key>
LLM_ENDPOINT=https://api.deepseek.com/v1
LLM_TEMPERATURE=0.0
COGNEE_SKIP_CONNECTION_TEST=true
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
GRAPH_DATABASE=networkx
VECTOR_DATABASE=lancedb
LOG_LEVEL=ERROR
COGNEE_LOG_FILE=false
